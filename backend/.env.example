# Backend Environment Variables

# Application
APP_NAME=Adaptive Learning Platform
APP_VERSION=2.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/adaptive_learning
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Anthropic API (fallback)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Pinecone (Vector DB)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=adaptive-learning

# AWS S3 / Cloudflare R2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=adaptive-learning-pdfs

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@adaptivelearning.com

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Feature Flags
ENABLE_RL_SCHEDULER=False
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_ANTI_CHEAT=True
