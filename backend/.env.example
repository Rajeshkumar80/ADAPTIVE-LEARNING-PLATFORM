# Backend Environment Variables

# Application
APP_NAME=AdaptLearn API
APP_VERSION=2.1.0
DEBUG=True
ENVIRONMENT=development

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./adaptlearn.db
# DATABASE_URL=postgresql://postgres:password@localhost:5432/adaptive_learning

# JWT Authentication
SECRET_KEY=change-this-secret-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# AI Services (set at least one for AI features)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_MODEL=google/gemini-2.5-pro

# Email (Resend API — optional)
RESEND_API_KEY=
FROM_EMAIL=noreply@adaptlearn.com

# Redis (optional — for caching and task queue)
REDIS_URL=redis://localhost:6379/0
