{
  "agent": {
    "name": "Rajuu-CodeShip",
    "model": "claude-sonnet-4-20250514",
    "version": "1.0",
    "purpose": "Ship production SaaS code fast for placement (14-16 LPA)"
  },
  "optimization": {
    "cache_system_prompt": true,
    "cache_ttl_seconds": 3600,
    "max_context_window": 50000,
    "context_pruning": {
      "enabled": true,
      "aggressive": false,
      "max_files": 10,
      "max_file_size_kb": 50
    },
    "streaming": true,
    "batch_mode": {
      "enabled": true,
      "min_tasks": 5,
      "process_async": true
    },
    "output_format": "json",
    "remove_explanations": true,
    "few_shot_examples": 2
  },
  "token_budgets": {
    "input_max": 8000,
    "output_max": 8000,
    "total_per_task": 16000,
    "monthly_limit": 500000
  },
  "mcp_servers": [
    {
      "name": "github-mcp",
      "url": "https://github-mcp.api.github.com",
      "enabled": true,
      "auth_required": true,
      "auth_type": "github_token",
      "priority": 1
    },
    {
      "name": "web-mcp",
      "url": "https://web-mcp.search.googleapis.com",
      "enabled": true,
      "auth_required": false,
      "priority": 2
    },
    {
      "name": "filesystem-mcp",
      "url": "local",
      "enabled": true,
      "auth_required": false,
      "priority": 1
    }
  ],
  "skills": {
    "priority_a": [
      "code-generation-advanced",
      "api-integration-fastapi",
      "react-nextjs-patterns",
      "postgres-schema-design",
      "error-handling-production",
      "api-documentation"
    ],
    "priority_b": [
      "fullstack-auth-oauth",
      "performance-optimization",
      "testing-unittest-pytest",
      "ci-cd-github-actions",
      "docker-containerization",
      "deployment-vercel-render"
    ],
    "priority_c": [
      "code-review-patterns",
      "refactoring-legacy",
      "security-scanning",
      "accessibility-wcag",
      "logging-monitoring"
    ]
  },
  "gemini": {
    "enabled": true,
    "model": "gemini-2.0-flash",
    "api_key": "${GEMINI_API_KEY}",
    "fallback": true,
    "max_tokens": 8000,
    "temperature": 0.2,
    "top_p": 0.9,
    "caching": {
      "enabled": true,
      "ttl_seconds": 3600
    },
    "retry_policy": {
      "max_attempts": 3,
      "backoff_type": "exponential"
    }
  },
  "context": {
    "user": "Rajuu",
    "role": "CSE student, final year (6th sem+)",
    "college": "Gopalan College of Engineering, Bengaluru",
    "degree": "VTU 22 scheme",
    "goal": "Off-campus placement - Bangalore product startups",
    "salary_target": "14-16 LPA",
    "stack": {
      "frontend": "Next.js 15, React, TypeScript",
      "backend": "FastAPI, Python",
      "database": "PostgreSQL",
      "deployment": "Vercel, Render"
    },
    "active_projects": [
      "Adaptive Learning Platform (Next.js + FastAPI + PostgreSQL)",
      "DevFlow (Code Review Platform)",
      "SaaS shipping (multiple quick projects)"
    ],
    "hardware": {
      "device": "ASUS A16",
      "cpu": "Ryzen 7",
      "ram": "16GB",
      "gpu": "RTX 4050"
    }
  },
  "workflows": {
    "fullstack_shipping": {
      "enabled": true,
      "agents": [
        "code-generator",
        "api-builder",
        "tester",
        "deployer"
      ],
      "timeout_seconds": 600
    },
    "code_review": {
      "enabled": true,
      "agents": [
        "reviewer",
        "optimizer",
        "security"
      ],
      "timeout_seconds": 300
    }
  },
  "logging": {
    "enabled": true,
    "log_dir": "~/antigravity-workspace/agent-logs",
    "log_format": "json",
    "log_level": "info",
    "metrics": [
      "tokens_used",
      "execution_time",
      "cache_hit_rate",
      "cost"
    ]
  },
  "output": {
    "format": "json",
    "include_commands": true,
    "include_tokens": true,
    "include_timing": true,
    "streaming": true
  },
  "consistency": {
    "before_coding": [
      "check_cache_status",
      "load_skill",
      "set_context"
    ],
    "during_coding": [
      "json_output_only",
      "log_to_agent_logs",
      "batch_similar_tasks"
    ],
    "after_coding": [
      "test_locally",
      "push_logs",
      "analyze_cache"
    ]
  }
}
